# Ключи внешних сервисов (через запятую можно несколько)
GROQ_API_KEYS=
GEMINI_API_KEYS=

# Модели Gemini по этапам (приоритетный список, fallback при 429)
GEMINI_MODELS_SPLIT=gemini-3.5-flash,gemini-3-flash-preview
GEMINI_MODELS_SUBSPLIT=gemini-3.5-flash,gemini-3-flash-preview
GEMINI_MODELS_RENDER=gemini-3.1-flash-lite,gemini-3.5-flash,gemini-3-flash-preview
GEMINI_MODELS_VIDEO_SLIDES=gemini-3-flash-preview,gemini-3.5-flash

# Параллельность вызовов Gemini по этапам
GEMINI_CONCURRENCY_SUBSPLIT=2
GEMINI_CONCURRENCY_RENDER=5
GEMINI_CONCURRENCY_VIDEO=5

# База данных
CORE_POSTGRES_PASSWORD=
# Пример для запуска вне Docker Compose:
# DATABASE_URL=postgresql+asyncpg://lecturelog:<CORE_POSTGRES_PASSWORD>@localhost:5432/lecturelog
DATABASE_URL=

# Хранилище лекций (S3/MinIO): исходники в uploads/, результаты в results/
# internal — endpoint движка внутри docker-сети
S3_INTERNAL_ENDPOINT=http://minio:9000
S3_BUCKET=lectures
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PRESIGN_EXPIRY=3600
# public (опционально): хост для presigned-ссылок наружу (PUT-загрузка/GET-скачка).
# Без него presigned не выдаётся (эндпоинты /uploads и /result-url отдают 409),
# работает только стрим GET /result — безопасный дефолт автономии.
# S3_PUBLIC_ENDPOINT=https://files.example

# Воркер
MAX_CONCURRENT_TASKS=2

# Вебхук на терминальные события (опционально; без URL движок работает автономно)
# PLATFORM_CALLBACK_URL=https://platform.example/lecturelog/callback
# LECTURELOG_WEBHOOK_SECRET=
