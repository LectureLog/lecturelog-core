# Docker image channel: dev, latest или конкретный релиз vX.Y.Z.
LECTURELOG_CORE_IMAGE_TAG=dev

# Локальные порты на VPS. Наружу их должен публиковать reverse proxy.
CORE_HTTP_PORT=8000
CORE_MINIO_PORT=9000
CORE_MINIO_CONSOLE_PORT=9001

# Пароль Postgres ядра. Заполните на сервере: openssl rand -hex 24
CORE_POSTGRES_PASSWORD=

# Ключи внешних сервисов.
GROQ_API_KEYS=
GEMINI_API_KEYS=

GEMINI_MODELS_SPLIT=gemini-3.5-flash,gemini-3-flash-preview
GEMINI_MODELS_SUBSPLIT=gemini-3.5-flash,gemini-3-flash-preview
GEMINI_MODELS_RENDER=gemini-3.1-flash-lite,gemini-3.5-flash,gemini-3-flash-preview
GEMINI_MODELS_VIDEO_SLIDES=gemini-3-flash-preview,gemini-3.5-flash
GEMINI_CONCURRENCY_SUBSPLIT=2
GEMINI_CONCURRENCY_RENDER=5
GEMINI_CONCURRENCY_VIDEO=5

# S3/MinIO. S3_PUBLIC_ENDPOINT должен быть доступен браузеру.
S3_PUBLIC_ENDPOINT=https://files.example.com
S3_BUCKET=lectures
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PRESIGN_EXPIRY=3600

MAX_CONCURRENT_TASKS=2

# URL web-платформы для вебхука ядра. Это не Google OAuth callback.
PLATFORM_CALLBACK_URL=https://app.example.com/webhooks/core

# Общий HMAC-секрет с lecturelog-web. Заполните одинаковым значением в web и core.
LECTURELOG_WEBHOOK_SECRET=
